[Unit]
Description=Pilot Code Bridge
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/pilot-code
ExecStart=/home/ubuntu/pilot-code/node_modules/.bin/tsx src/index.ts
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
